# Database — SQLite for dev, swap to PostgreSQL for production
# Dev:  DATABASE_URL="file:./dev.db"
# Prod: DATABASE_URL="postgresql://user:password@host:5432/vitacare"
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET="change-me-in-production-use-32-chars-min"
JWT_REFRESH_SECRET="another-secret-for-refresh-tokens"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="30d"

# OTP — set to "console" for dev (logs OTP), or "msg91" for production
OTP_PROVIDER="console"
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""

# Claude AI — for lab report analysis
ANTHROPIC_API_KEY=""

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed origins
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"
